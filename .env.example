# Discord user token (REQUIRED)
# 获取方式：浏览器登录 Discord → F12 打开开发者工具 → Network → 任意请求 → Headers → authorization
# ⚠️ 绝不要把真实 token 提交到 git
DISCORD_USER_TOKEN=your_discord_user_token_here

# Optional: HTTP proxy (留空则直连)
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# Optional: 输出 JSON 文件路径（不设置则只打印到终端）
# OUTPUT_JSON=output/roles.json
